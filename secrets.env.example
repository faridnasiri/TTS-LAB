# secrets.env.example — commit this, NOT secrets.env
# Copy to secrets.env and fill in real values

GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
HF_TOKEN=YOUR_HUGGINGFACE_TOKEN_HERE   # needed for gated models: csm, orpheus
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE    # magic prompt via OpenRouter (DeepSeek)
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE        # magic prompt via DeepSeek native API
IDEOGRAM_API_KEY=YOUR_IDEOGRAM_API_KEY_HERE         # magic prompt via Ideogram hosted API (free, best)
