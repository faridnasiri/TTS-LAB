# TTS Lab — Docker Environment Variables
# Copy to .env and fill in values. .env is gitignored.

# HuggingFace token (for gated models: orpheus, csm, qwen3tts)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: override SGLang URLs (defaults use Docker service names)
# VIBEVOICE_SGLANG_URL=http://vibevoice:8000/v1/audio/speech
# HIGGS_SGLANG_URL=http://higgs:8000/v1/audio/speech
# S2PRO_SGLANG_URL=http://s2pro:8000/v1/audio/speech
