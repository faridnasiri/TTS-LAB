# syntax=docker/dockerfile:1
# ═══════════════════════════════════════════════════════════════════
# TIER 3 — engine-qwen  (1 engine: Qwen3-TTS 1.7B Base — voice cloning)
# ═══════════════════════════════════════════════════════════════════
#
# Dedicated container — no dependency drift into engine-current.
#
# Qwen3-TTS requires a narrow version window that conflicts with
# both engine-current (torch nightly, tf 5.12, hf-hub >= 1.0)
# and engine-legacy (torch 1.13 too old for qwen_tts).
#
# STACK (inherited from tts-lab-stack-mid):
#   torch 2.10 stable (cu121)   — stable, well-tested CUDA 12.1
#   transformers 4.x            — before ROPE API removal in 5.x
#   No nightly regressions
#   No install-then-downgrade
#
# PINNED (this layer):
#   transformers == 4.53.3      — auto_docstring present (>= 4.52), before
#                                  TransformGetItemToIndex (>= 4.54)
#   huggingface-hub 0.34–1.0    — qwen_tts 0.1.1 compatibility
#   qwen-tts == 0.1.1           — last known-compatible release
#
# INCOMPATIBILITIES THIS AVOIDS:
#   - ROPE_INIT_FUNCTIONS["default"] removed in tf 5.x
#   - TransformGetItemToIndex added in tf 4.54 (qwen_tts 0.1.1 crashes)
#   - huggingface-hub >= 1.0 removes is_offline_mode (qwen_tts 0.1.1)
#   - inputs_embeds signature changed in tf 5.x
#   Deployed fix: install qwen-tts first, then --force-reinstall tf==4.51.3
#
# MODEL: Qwen/Qwen3-TTS-12Hz-1.7B-Base  (gated — needs HF_TOKEN)
# Switched from CustomVoice (no voice clone) to Base (generate_voice_clone + x-vector mode)
#
# MATURITY: SUPPORTED — deployed on engine-qwen, voice cloning verified
#
# SIZE: ~8 GB (stack-mid ~4.5 + qwen_tts + model weights ~3 GB)
# ═══════════════════════════════════════════════════════════════════

FROM tts-lab-stack-mid:latest
LABEL org.opencontainers.image.title="TTS Lab — Engine Server (qwen)"
LABEL org.opencontainers.image.description="Qwen3-TTS 1.7B — torch 2.10 stable + tf 4.51-4.54"
LABEL tts-lab.tier="3-engine"
LABEL tts-lab.stack="qwen"
LABEL tts-lab.maturity="experimental"

# ── qwen_tts with its preferred transformers ──────────────────────
# qwen_tts 0.1.1 requires transformers==4.57.3 (exact pin in metadata).
# TransformGetItemToIndex in masking_utils is patched at runtime by
# tts_lab_shims.py with a working no-op context manager.
RUN pip install --no-cache-dir qwen-tts==0.1.1

RUN pip install --no-cache-dir "huggingface-hub>=0.34,<1.0"

# ── Build-time validation — fail fast, not at runtime ─────────────
# TransformGetItemToIndex is patched at runtime by tts_lab_shims.py.
RUN python3 -c "import qwen_tts; print('qwen_tts OK')" \
    && python3 -c "from qwen_tts import Qwen3TTSModel; print('Qwen3TTSModel OK')" \
    && python3 -c "from transformers.modeling_rope_utils import ROPE_INIT_FUNCTIONS; assert 'default' in ROPE_INIT_FUNCTIONS, 'ROPE_INIT_FUNCTIONS missing default'; print('ROPE default OK')"

# ── Shared audio processing ───────────────────────────────────────
RUN pip install --no-cache-dir scipy librosa soundfile

# ── Engine server code ────────────────────────────────────────────
COPY tts_lab_shims.py /opt/arthur/
COPY tts_lab_config.py /opt/arthur/
COPY tts_lab_engine_server.py /opt/arthur/
COPY tts_lab_engines.py /opt/arthur/
COPY tts_lab_dispatch.py /opt/arthur/

EXPOSE 8104
HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=120s \
    CMD curl -f http://localhost:8104/health || exit 1
CMD ["python3", "/opt/arthur/tts_lab_engine_server.py", "--port", "8104", "--stack", "current"]
